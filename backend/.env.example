# Local Postgres for development:
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/nutriadd

# Neon (production) — in the Neon dashboard, toggle "Pooled connection" ON before
# copying the string (pooled host has a "-pooler" suffix). Use the pooled string for
# the running app (Render) since it handles many short-lived connections well and
# survives Neon's autosuspend/resume; use the *unpooled* string only for one-off
# Alembic migration runs from your own machine. Switch the scheme to
# postgresql+asyncpg and append ?ssl=require, e.g.:
# DATABASE_URL=postgresql+asyncpg://neondb_owner:xxxx@ep-xxxx-pooler.region.aws.neon.tech/neondb?ssl=require
#
# (app/db/base.py already disables asyncpg's prepared-statement cache automatically
# when it detects postgresql+asyncpg, which is required for Neon's pooled/PgBouncer
# connection to work correctly.)

JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Comma-separated (or JSON array) list of allowed frontend origins.
# Add your Vercel preview/production URLs and, later, your custom domain — no code change needed.
CORS_ORIGINS=http://localhost:5173,https://nutriadd.vercel.app

ENVIRONMENT=development
