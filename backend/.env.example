# ---------------------------------------------------------------------------
# NutriAdd backend environment variables.
# Copy to `.env` and fill in real values. On the Azure VM, keep this file
# readable only by the service user:  chmod 600 .env
# ---------------------------------------------------------------------------

# Database — Azure Database for MySQL Flexible Server (async driver: aiomysql).
# Local development against a local MySQL:
DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/nutriadd
# Production (Azure MySQL Flexible Server). TLS is applied automatically for any
# non-localhost host — no ?ssl= flag needed in the URL. Example:
# DATABASE_URL=mysql+aiomysql://nutriadd_app:CHANGE_ME@nutriadd-db.mysql.database.azure.com:3306/nutriadd

# JWT
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS — comma-separated (or JSON array) list of allowed frontend origins.
# Add your Vercel URL(s) and, later, your custom domain — no code change needed.
CORS_ORIGINS=http://localhost:5173,https://nutriadd.vercel.app

# Azure Blob Storage — all product/promo/document media lives here; the DB only
# stores the resulting HTTPS URLs, never binary data.
# Authenticate with EITHER a full connection string, OR account name + key
# (Azure Portal -> Storage account -> Access keys). Leave the unused option blank.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
# Must match the REAL container names in your storage account.
AZURE_STORAGE_PRODUCT_CONTAINER=product-images
AZURE_STORAGE_PROMO_CONTAINER=promo-media

# App
ENVIRONMENT=development

# ---------------------------------------------------------------------------
# Resend (transactional email) — currently consumed by the frontend's
# /api/contact serverless function (configured in Vercel, not here) and by the
# backend's stubbed password-reset hook. Set here only once the backend actually
# sends email (see app/services/auth_service.py::send_reset_email TODO).
# RESEND_API_KEY=
# ---------------------------------------------------------------------------
