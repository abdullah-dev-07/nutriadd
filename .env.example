# Resend transactional email (used by the /api/contact serverless function in Phase 8)
RESEND_API_KEY=

# Address that receives contact-form submissions
CONTACT_TO_EMAIL=abdullah.usaf2002@gmail.com
#info@lifecare.com

# Verified "from" sender configured in your Resend account
CONTACT_FROM_EMAIL=onboarding@resend.dev
#website@nutriadd.com

# Public site URL (used for canonical URLs, sitemap, Open Graph).
# Set this in Vercel's Environment Variables to your *.vercel.app URL for now;
# swap it for your custom domain later — no code change needed.
VITE_SITE_URL=https://nutriadd.vercel.app

# Base URL for the FastAPI backend (products, cart/orders, auth).
# Local dev: http://localhost:8000/api/v1
# Production: set in Vercel to your Railway backend URL, e.g.
# https://nutriadd-backend.up.railway.app/api/v1
VITE_API_URL=http://localhost:8000/api/v1
